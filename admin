                    <div class="grid grid-cols-2 gap-4 mb-2 bg-white p-3 rounded border border-gray-200">
                        <div><label class="text-[10px] uppercase font-bold text-gray-400">First Name</label><input type="text" id="edit-c-fname-${i}" value="${c.firstName}" class="w-full border-b border-gray-300 font-bold outline-none text-sm"></div>
