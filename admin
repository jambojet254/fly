    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { jambo: { red: '#E61C24', darkred: '#CC1820', slate: '#2A3342', gold: '#D4AF37' } },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
