    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collectionGroup, getDocs, doc, updateDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Same Config as Main App
        const firebaseConfig = {
            apiKey: "AIzaSyDI58JasEcIaOiLd7WbcEiFfC2mz_a7RhM", authDomain: "jamboj.firebaseapp.com", projectId: "jamboj", storageBucket: "jamboj.firebasestorage.app", messagingSenderId: "486318488452", appId: "1:486318488452:web:5e4be2abec797f2d19bbd1", measurementId: "G-2KCMTC7GG5"
        };
        
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        window.db = getFirestore(app);

        // State
        window.AdminState = {
            bookings: [],
            users: [],
            stats: {}
        };

        // Safe Timestamp Parser Helper
        window.getSafeMillis = (ts) => {
            if(!ts) return 0;
            if(typeof ts.toMillis === 'function') return ts.toMillis();
            if(ts.seconds) return ts.seconds * 1000;
            return new Date(ts).getTime() || 0;
        };

        window.handleLogin = async (e) => {
            e.preventDefault();
            const pass = document.getElementById('passcode-input').value;
            if(pass === '115800') {
                document.getElementById('login-error').classList.add('hidden');
                document.getElementById('login-screen').classList.add('hidden');
                document.getElementById('main-app').classList.remove('hidden');
                document.getElementById('main-app').classList.add('flex');
                
                // Login anonymously to firebase to utilize the open rules
                try {
                    await signInAnonymously(auth);
                    window.refreshData();
                } catch(err) {
                    alert("Firebase Connection Error: " + err.message);
                }
            } else {
                document.getElementById('login-error').classList.remove('hidden');
            }
        };

        window.switchView = (viewId) => {
            document.querySelectorAll('.view-section').forEach(el => el.classList.remove('view-active'));
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('bg-jambo-red', 'text-white', 'shadow-lg');
                btn.classList.add('hover:bg-slate-800', 'hover:text-white', 'text-slate-300');
            });
            
            document.getElementById(`view-${viewId}`).classList.add('view-active');
            const activeBtn = document.getElementById(`nav-${viewId}`);
            activeBtn.classList.remove('hover:bg-slate-800', 'hover:text-white', 'text-slate-300');
            activeBtn.classList.add('bg-jambo-red', 'text-white', 'shadow-lg');
        };

        const showLoader = (text) => { document.getElementById('loader-text').innerText = text; document.getElementById('global-loader').classList.remove('hidden'); };
        const hideLoader = () => { document.getElementById('global-loader').classList.add('hidden'); };
        const showToast = (msg) => { 
            document.getElementById('toast-msg').innerText = msg; 
            const t = document.getElementById('toast');
            t.classList.remove('opacity-0', 'translate-y-[-20px]'); 
            setTimeout(() => t.classList.add('opacity-0', 'translate-y-[-20px]'), 3000); 
        };

        window.refreshData = async () => {
            showLoader("Syncing Database...");
            try {
                // Fetch ALL bookings across ALL users via collectionGroup
                const bksQuery = collectionGroup(window.db, 'bookings');
                const bksSnapshot = await getDocs(bksQuery);
                const bks = [];
                bksSnapshot.forEach(doc => { bks.push({ id: doc.id, path: doc.ref.path, ...doc.data() }); });
                // Sort newest first safely
                bks.sort((a,b) => window.getSafeMillis(b.createdAt) - window.getSafeMillis(a.createdAt));
                window.AdminState.bookings = bks;

                // Fetch ALL users profiles
                const usersQuery = collectionGroup(window.db, 'profile');
                const usersSnapshot = await getDocs(usersQuery);
                const users = [];
                usersSnapshot.forEach(doc => { 
                    // Filter to only get the actual userData documents, ignoring nested ones if any
                    if(doc.id === 'userData') users.push({ uid: doc.ref.parent.parent.id, ...doc.data() }); 
                });
                window.AdminState.users = users;

                computeMegaStats();
                renderDashboard();
                renderBookingsTable();
                renderTransactionsTable();
                renderUsersTable();
                renderReportsPage();
                
                hideLoader();
                showToast("Data Synced Successfully");
            } catch (err) {
                hideLoader();
                console.error(err);
                alert("Error fetching data. Check Firebase Rules. " + err.message);
            }
        };

        function computeMegaStats() {
            const b = window.AdminState.bookings;
            const u = window.AdminState.users;
            
            let s = {
                // 1-10: High Level Financials & Counts
                totalRev: 0, totalBks: b.length, totalPax: 0, totalUsers: u.length,
                totalAdults: 0, totalChildren: 0, avgRevPerBk: 0, avgPaxPerBk: 0,
                
                // 11-20: Payment Methods
                totalMpesa: 0, totalCards: 0, revMpesa: 0, revCards: 0, mpesaPercent: 0, cardPercent: 0,
                
                // 21-30: Add-ons & Fees
                totalBags: 0, revBags: 0, totalPremiumSeats: 0, revSeats: 0, totalPromoDiscounts: 0,
                
                // 31-40: Flight Demographics
                statusConfirmed: 0, statusCheckedIn: 0, statusCancelled: 0, 
                tripOneWay: 0, tripReturn: 0,
                
                // 41-52: Routes & Custom
                routeCount: {}, titleDemographics: { Mr:0, Mrs:0, Miss:0, Ms:0, Dr:0 },
                nationalityCount: {}
            };

            b.forEach(bk => {
                const amt = parseInt(bk.totalAmount?.toString().replace(/,/g, '') || 0);
                s.totalRev += amt;
                s.totalPax += (bk.adults + bk.children);
                s.totalAdults += bk.adults; s.totalChildren += bk.children;
                
                if(bk.paymentMethod && bk.paymentMethod.includes('M-PESA')) { s.totalMpesa++; s.revMpesa += amt; }
                else { s.totalCards++; s.revCards += amt; }

                if(bk.extras) {
                    s.totalBags += (bk.extras.baggageCount || 0);
                    s.revBags += (bk.extras.baggageCost || 0);
                    if((bk.extras.seatCost || 0) > 0) { s.totalPremiumSeats += (bk.adults + bk.children); s.revSeats += ((bk.extras.seatCost || 0) * (bk.adults + bk.children)); }
                    s.totalPromoDiscounts += (bk.extras.promoDiscount || 0);
                }

                if(bk.status === 'Confirmed') s.statusConfirmed++;
                else if(bk.status === 'Checked-In') s.statusCheckedIn++;
                else s.statusCancelled++;

                if(bk.return) s.tripReturn++; else s.tripOneWay++;

                // Route counting
                s.routeCount[bk.route] = (s.routeCount[bk.route] || 0) + 1;
                
                // Titles
                if(bk.title && s.titleDemographics[bk.title] !== undefined) s.titleDemographics[bk.title]++;
            });

            u.forEach(user => {
                if(user.nationality) s.nationalityCount[user.nationality] = (s.nationalityCount[user.nationality] || 0) + 1;
            });

            s.avgRevPerBk = s.totalBks > 0 ? (s.totalRev / s.totalBks) : 0;
            s.avgPaxPerBk = s.totalBks > 0 ? (s.totalPax / s.totalBks) : 0;
            s.mpesaPercent = s.totalBks > 0 ? ((s.totalMpesa / s.totalBks) * 100).toFixed(1) : 0;
            s.cardPercent = s.totalBks > 0 ? ((s.totalCards / s.totalBks) * 100).toFixed(1) : 0;

            window.AdminState.stats = s;
        }

        let chart1, chart2;
