                    <div class="bg-blue-50 text-blue-800 p-4 rounded-xl mb-6 font-bold border border-blue-200 flex items-center gap-3"><i class="fa-solid fa-file-invoice text-xl"></i> PNR: ${bk.ref}</div>
                    
