            document.getElementById('edit-form-container').innerHTML = html;
            document.getElementById('edit-modal').classList.remove('hidden');
        };

        window.closeEditModal = () => document.getElementById('edit-modal').classList.add('hidden');

        window.saveEdit = async (e, path, id) => {
            e.preventDefault();
            showLoader("Updating Document in Firestore...");
            try {
                // We use the exact path extracted during collectionGroup query to update the specific nested document
                const docRef = doc(window.db, path);
                
                const bk = window.AdminState.bookings.find(b => b.id === id);
                let newChildren = bk.passengerData?.childrenArr || [];
                // if children exist, grab updated values
                newChildren = newChildren.map((c, i) => {
                    const fn = document.getElementById(`edit-c-fname-${i}`)?.value || c.firstName;
                    const ln = document.getElementById(`edit-c-lname-${i}`)?.value || c.lastName;
                    return {...c, firstName: fn.toUpperCase(), lastName: ln.toUpperCase()};
                });

                const payload = {
                    status: document.getElementById('edit-status').value,
                    totalAmount: document.getElementById('edit-total').value,
                    firstName: document.getElementById('edit-fname').value.toUpperCase(),
                    lastName: document.getElementById('edit-lname').value.toUpperCase(),
                    email: document.getElementById('edit-email').value,
                    'passengerData.idPass': document.getElementById('edit-doc').value.toUpperCase(),
                    'passengerData.childrenArr': newChildren
                };

                await updateDoc(docRef, payload);
                closeEditModal();
                await window.refreshData(); // Refresh UI memory
            } catch(err) {
                hideLoader(); alert("Update Failed: " + err.message);
            }
        };

