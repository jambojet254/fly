                                    </select>
                                </div>
                                <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Total Amount (KES - Formatting Required)</label><input type="text" id="edit-total" value="${bk.totalAmount}" class="w-full p-3 bg-white border border-gray-300 rounded-lg font-bold outline-none focus:border-jambo-red"></div>
                            </div>
                        </div>
                        <div>
                            <h4 class="font-extrabold text-jambo-slate mb-4 border-b border-gray-200 pb-2">Primary Passenger Data</h4>
                            <div class="space-y-4">
                                <div class="grid grid-cols-2 gap-4">
                                    <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">First Name</label><input type="text" id="edit-fname" value="${bk.firstName}" class="w-full p-3 bg-white border border-gray-300 rounded-lg font-bold outline-none uppercase"></div>
                                    <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Last Name</label><input type="text" id="edit-lname" value="${bk.lastName}" class="w-full p-3 bg-white border border-gray-300 rounded-lg font-bold outline-none uppercase"></div>
                                </div>
                                <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Email</label><input type="email" id="edit-email" value="${bk.email}" class="w-full p-3 bg-white border border-gray-300 rounded-lg font-bold outline-none"></div>
